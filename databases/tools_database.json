    "id": "TOOL-014",
    "name": "John the Ripper / Hashcat",
    "type": "password_cracking",
    "description": "Инструменты для взлома паролей через brute force и словарные атаки",
    "url": "https://www.openwall.com/john/",
    "applicable_attack_types": ["brute_force", "credential_dumping"],
    "applicable_cve": [],
    "commands": {
      "default": [
        "# John the Ripper - взлом NTLM хешей",
        "john --format=NT hashes.txt",
        "",
        "# С использованием словаря",
        "john --format=NT --wordlist=/usr/share/wordlists/rockyou.txt hashes.txt",
        "",
        "# Hashcat - GPU-ускоренный взлом",
        "hashcat -m 1000 -a 0 hashes.txt /usr/share/wordlists/rockyou.txt",
        "",
        "# Hashcat с маской (брутфорс)",
        "hashcat -m 1000 -a 3 hashes.txt ?a?a?a?a?a?a",
        "",
        "# Извлечение хешей из SAM файла (Windows)",
        "samdump2 SYSTEM SAM > hashes.txt"
      ]
    },
    "phases": ["Post-Exploitation"],
    "skill_level": "Intermediate",
    "os": ["Linux"]
