    "description": "Защита хранилища учётных данных от извлечения Mimikatz",
    "tools": [
      {
        "name": "Windows Defender Credential Guard",
        "description": "Аппаратная защита учётных данных через виртуализацию",
        "commands": [
          "# Проверка поддержки Credential Guard",
          "msinfo32",
          "",
          "# Включение через PowerShell",
          "$featureValue = (Get-ItemProperty -Path 'HKLM:\\SYSTEM\\CurrentControlSet\\Control\\DeviceGuard').EnableVirtualizationBasedSecurity",
          "Set-ItemProperty -Path 'HKLM:\\SYSTEM\\CurrentControlSet\\Control\\Lsa' -Name LsaCfgFlags -Value 1",
          "",
          "# Настройка через GPO:",
          "# Computer Configuration -> Windows Settings -> Security Settings",
          "# -> Local Policies -> Security Options",
          "# -> 'Interactive logon: Do not display last user name': Enabled"
        ]
      }
    ],
    "priority": "HIGH",
    "effort": "Medium",
    "effectiveness": "High"
  }
]
